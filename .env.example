# MySQL 데이터베이스 연결 설정
MYSQL_USER=your_mysql_user
MYSQL_PASSWORD=your_mysql_password
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3307
MYSQL_SCHEMA=mje

# CORS 설정 (프론트엔드 주소)
CORS_ORIGINS=["http://localhost:3000"]

# 네이버 검색 API (지역검색, 이미지검색)
NAVER_SEARCH_CLIENT_ID=your_client_id
NAVER_SEARCH_CLIENT_SECRET=your_client_secret

# 네이버 데이터랩 API (검색어 트렌드)
NAVER_DATALAB_CLIENT_ID=your_client_id
NAVER_DATALAB_CLIENT_SECRET=your_client_secret

# 네이버 지도 API (Static Map, Geocoding, Directions 등)
NAVER_MAP_CLIENT_ID=your_client_id
NAVER_MAP_CLIENT_SECRET=your_client_secret

# SMTP 설정
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM=your_email@gmail.com
